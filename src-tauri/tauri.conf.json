{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pzync",
  "version": "0.1.0",
  "identifier": "com.adhil.pzync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pzync",
        "label": "main",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "scrot",
          "xdotool",
          "wmctrl",
          "gnome-screenshot",
          "flameshot"
        ]
      }
    }
  }
}
